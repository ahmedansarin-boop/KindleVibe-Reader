<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Drop Shadow -->
    <path
        android:pathData="M22,26 Q22,22 26,22 L82,22 Q86,22 86,26 L86,82 Q86,86 82,86 L26,86 Q22,86 22,82 Z"
        android:fillColor="#26000000"
        android:translateX="2"
        android:translateY="2"/>

    <!-- Book Cover (Behind pages) -->
    <path
        android:pathData="M20,24 Q20,20 24,20 L84,20 Q88,20 88,24 L88,84 Q88,88 84,88 L24,88 Q20,88 20,84 Z"
        android:fillColor="#1E293B"/>

    <!-- Left Page -->
    <path
        android:pathData="M24,24 L54,24 L54,84 L24,84 Z"
        android:fillColor="#F8FAFC"/>

    <!-- Right Page -->
    <path
        android:pathData="M54,24 L84,24 L84,84 L54,84 Z"
        android:fillColor="#F1F5F9"/>

    <!-- Spine Shadow -->
    <path
        android:pathData="M54,24 L54,84"
        android:strokeColor="#CBD5E1"
        android:strokeWidth="1"/>

    <!-- Text Lines (Left Page) - Subtle -->
    <path
        android:pathData="M30,34 L48,34 M30,42 L48,42 M30,50 L48,50 M30,58 L44,58"
        android:strokeColor="#94A3B8"
        android:strokeWidth="2"
        android:strokeLineCap="round"/>

    <!-- Premium Gold Bookmark (Gradient) -->
    <path android:pathData="M70,20 L80,20 L80,50 L75,45 L70,50 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startY="20"
                android:endY="50"
                android:type="linear">
                <item android:offset="0" android:color="#FFF59E0B"/> <!-- Amber 500 -->
                <item android:offset="0.5" android:color="#FFD97706"/> <!-- Amber 600 -->
                <item android:offset="1" android:color="#FF92400E"/> <!-- Amber 800 -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Gold Spark/Accent Dot -->
    <path android:pathData="M40,70 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="40"
                android:centerY="70"
                android:gradientRadius="3"
                android:type="radial">
                <item android:offset="0" android:color="#FFF59E0B"/>
                <item android:offset="1" android:color="#FFB45309"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>